# =========================================================================
# Jaros — Environment Configuration Template
# =========================================================================
# Copy this file to '.env' in the root directory and fill in your values.
# The '.env' file is ignored by git and can hold your private API keys safely.
# =========================================================================

# The directory used by the shared file system control plane
JAROS_DATA_DIR=.jaros-data

# The execution tick rate of the background daemon (in milliseconds)
JAROS_TICK_MS=200

# Pluggable LLM provider adapter selection (e.g. 'default', 'uppercase', 'gemini')
JAROS_LLM_PROVIDER=default

# =========================================================================
# Custom LLM API Keys (Fill in when adding real provider adapters)
# =========================================================================
# GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
